generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  seatLimit Int       @default(1) @map("seat_limit")
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  budgets   Budget[]
  auditLogs AuditLog[]
  memberships Membership[]
  departments Department[]
  customers Customer[]
  contacts Contact[]
  projects Project[]
  milestones Milestone[]

  @@map("tenants")
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  actorUserId String?  @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  passwordHash  String         @map("password_hash")
  accessTokenVersion Int       @default(0) @map("access_token_version")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  memberships   Membership[]

  @@map("users")
}

model Membership {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  userId    String    @map("user_id")
  departmentId String? @map("department_id")
  role      String
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, status])
  @@index([departmentId])
  @@map("memberships")
}

model Department {
  id        String       @id @default(uuid())
  tenantId  String       @map("tenant_id")
  parentId  String?      @map("parent_id")
  name      String
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent    Department?  @relation("DepartmentTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  Department[] @relation("DepartmentTree")
  memberships Membership[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([parentId])
  @@index([deletedAt])
  @@map("departments")
}

model Customer {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  name      String
  status    String    @default("ACTIVE")
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  contacts  Contact[]
  projects  Project[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([deletedAt])
  @@map("customers")
}

model Contact {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  customerId String    @map("customer_id")
  name       String
  email      String?
  phone      String?
  title      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([customerId])
  @@index([deletedAt])
  @@map("contacts")
}

model Project {
  id               String      @id @default(uuid())
  tenantId         String      @map("tenant_id")
  customerId       String      @map("customer_id")
  name             String
  status           String      @default("DRAFT")
  source           String      @default("MANUAL")
  projectManagerId String      @map("project_manager_id")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  deletedAt        DateTime?   @map("deleted_at")
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer         Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  milestones       Milestone[]

  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, status])
  @@index([deletedAt])
  @@map("projects")
}

model Milestone {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  projectId  String    @map("project_id")
  name       String
  status     String    @default("PLANNED")
  dueDate    DateTime? @map("due_date")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([projectId])
  @@index([tenantId, status])
  @@index([deletedAt])
  @@map("milestones")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Budget {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  name      String
  amount    Decimal   @db.Decimal(18, 2)
  currency  String    @default("CNY")
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([deletedAt])
  @@map("budgets")
}
