generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  seatLimit Int       @default(1) @map("seat_limit")
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  budgets   Budget[]
  auditLogs AuditLog[]
  memberships Membership[]
  departments Department[]
  customers Customer[]
  contacts Contact[]
  projects Project[]
  milestones Milestone[]
  sprints Sprint[]
  tasks BacklogTask[]
  taskChanges TaskChange[]
  employees Employee[]
  skills Skill[]
  employeeSkills EmployeeSkill[]
  capacities Capacity[]
  resourceAllocations ResourceAllocation[]
  timeEntries TimeEntry[]
  costEntries CostEntry[]

  @@map("tenants")
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  actorUserId String?  @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  passwordHash  String         @map("password_hash")
  accessTokenVersion Int       @default(0) @map("access_token_version")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  memberships   Membership[]

  @@map("users")
}

model Membership {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  userId    String    @map("user_id")
  departmentId String? @map("department_id")
  role      String
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, status])
  @@index([departmentId])
  @@map("memberships")
}

model Department {
  id        String       @id @default(uuid())
  tenantId  String       @map("tenant_id")
  parentId  String?      @map("parent_id")
  name      String
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent    Department?  @relation("DepartmentTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  Department[] @relation("DepartmentTree")
  memberships Membership[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([parentId])
  @@index([deletedAt])
  @@map("departments")
}

model Customer {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  name      String
  status    String    @default("ACTIVE")
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  contacts  Contact[]
  projects  Project[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([deletedAt])
  @@map("customers")
}

model Contact {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  customerId String    @map("customer_id")
  name       String
  email      String?
  phone      String?
  title      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([customerId])
  @@index([deletedAt])
  @@map("contacts")
}

model Project {
  id               String      @id @default(uuid())
  tenantId         String      @map("tenant_id")
  customerId       String      @map("customer_id")
  name             String
  status           String      @default("DRAFT")
  source           String      @default("MANUAL")
  projectManagerId String      @map("project_manager_id")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  deletedAt        DateTime?   @map("deleted_at")
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer         Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  milestones       Milestone[]
  sprints          Sprint[]
  tasks            BacklogTask[]
  resourceAllocations ResourceAllocation[]
  costEntries      CostEntry[]

  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, status])
  @@index([deletedAt])
  @@map("projects")
}

model Milestone {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  projectId  String    @map("project_id")
  name       String
  status     String    @default("PLANNED")
  dueDate    DateTime? @map("due_date")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([projectId])
  @@index([tenantId, status])
  @@index([deletedAt])
  @@map("milestones")
}

model Sprint {
  id        String        @id @default(uuid())
  tenantId  String        @map("tenant_id")
  projectId String        @map("project_id")
  name      String
  goal      String?
  status    String        @default("PLANNED")
  startDate DateTime?     @map("start_date")
  endDate   DateTime?     @map("end_date")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  tasks     BacklogTask[]
  changes   TaskChange[]

  @@index([tenantId])
  @@index([projectId])
  @@index([tenantId, status])
  @@index([deletedAt])
  @@map("sprints")
}

model BacklogTask {
  id            String       @id @default(uuid())
  tenantId      String       @map("tenant_id")
  projectId     String       @map("project_id")
  sprintId      String?      @map("sprint_id")
  title         String
  description   String?
  estimateHours Decimal      @map("estimate_hours") @db.Decimal(10, 2)
  status        String       @default("TODO")
  boardColumn   String       @default("TODO") @map("board_column")
  assigneeUserId String?     @map("assignee_user_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  sprint        Sprint?      @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  changes       TaskChange[]
  resourceAllocations ResourceAllocation[]
  timeEntries   TimeEntry[]
  costEntries   CostEntry[]

  @@index([tenantId])
  @@index([projectId])
  @@index([sprintId])
  @@index([tenantId, status])
  @@index([tenantId, boardColumn])
  @@index([deletedAt])
  @@map("tasks")
}

model TaskChange {
  id                     String      @id @default(uuid())
  tenantId               String      @map("tenant_id")
  taskId                 String      @map("task_id")
  sprintId               String?     @map("sprint_id")
  fromStatus             String?     @map("from_status")
  toStatus               String      @map("to_status")
  remainingEstimateHours Decimal     @map("remaining_estimate_hours") @db.Decimal(10, 2)
  changedAt              DateTime    @default(now()) @map("changed_at")
  tenant                 Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  task                   BacklogTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sprint                 Sprint?     @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([taskId])
  @@index([sprintId])
  @@index([changedAt])
  @@map("task_changes")
}

model Employee {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  name        String
  email       String?
  costRate    Decimal         @map("cost_rate") @db.Decimal(10, 2)
  currency    String          @default("CNY")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  skills      EmployeeSkill[]
  capacities  Capacity[]
  resourceAllocations ResourceAllocation[]
  timeEntries TimeEntry[]
  costEntries CostEntry[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([deletedAt])
  @@map("employees")
}

model Skill {
  id        String          @id @default(uuid())
  tenantId  String          @map("tenant_id")
  name      String
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  deletedAt DateTime?       @map("deleted_at")
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employees EmployeeSkill[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([deletedAt])
  @@map("skills")
}

model EmployeeSkill {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  employeeId String   @map("employee_id")
  skillId    String   @map("skill_id")
  level      String   @default("MID")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@unique([tenantId, employeeId, skillId])
  @@index([tenantId])
  @@index([employeeId])
  @@index([skillId])
  @@map("employee_skills")
}

model Capacity {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  employeeId    String    @map("employee_id")
  weeklyHours   Decimal   @map("weekly_hours") @db.Decimal(10, 2)
  effectiveFrom DateTime  @default(now()) @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
  @@index([effectiveFrom])
  @@index([deletedAt])
  @@map("capacities")
}

model ResourceAllocation {
  id                     String       @id @default(uuid())
  tenantId               String       @map("tenant_id")
  employeeId             String       @map("employee_id")
  projectId              String       @map("project_id")
  taskId                 String?      @map("task_id")
  weekStart              DateTime     @map("week_start")
  plannedHours           Decimal      @map("planned_hours") @db.Decimal(10, 2)
  availableHoursOverride Decimal?     @map("available_hours_override") @db.Decimal(10, 2)
  isOverloaded           Boolean      @default(false) @map("is_overloaded")
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")
  deletedAt              DateTime?    @map("deleted_at")
  tenant                 Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employee               Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  project                Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  task                   BacklogTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([employeeId])
  @@index([projectId])
  @@index([taskId])
  @@index([weekStart])
  @@index([deletedAt])
  @@map("resource_allocations")
}

model TimeEntry {
  id                String      @id @default(uuid())
  tenantId          String      @map("tenant_id")
  taskId            String      @map("task_id")
  employeeId        String      @map("employee_id")
  hours             Decimal     @db.Decimal(10, 2)
  source            String      @default("AUTO")
  note              String?
  correctedByUserId String?     @map("corrected_by_user_id")
  correctedAt       DateTime?   @map("corrected_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  task              BacklogTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employee          Employee    @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  costEntries       CostEntry[]

  @@unique([tenantId, taskId, employeeId])
  @@index([tenantId])
  @@index([taskId])
  @@index([employeeId])
  @@index([source])
  @@index([deletedAt])
  @@map("time_entries")
}

model CostEntry {
  id            String      @id @default(uuid())
  tenantId      String      @map("tenant_id")
  projectId     String      @map("project_id")
  taskId        String?     @map("task_id")
  employeeId    String?     @map("employee_id")
  timeEntryId   String?     @map("time_entry_id")
  type          String
  amount        Decimal     @db.Decimal(12, 2)
  currency      String      @default("CNY")
  quantityHours Decimal?    @map("quantity_hours") @db.Decimal(10, 2)
  unitCostRate  Decimal?    @map("unit_cost_rate") @db.Decimal(10, 2)
  source        String      @default("SYSTEM")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Restrict)
  task          BacklogTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  employee      Employee?   @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  timeEntry     TimeEntry?  @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)

  @@unique([tenantId, timeEntryId, type])
  @@index([tenantId])
  @@index([projectId])
  @@index([taskId])
  @@index([employeeId])
  @@index([timeEntryId])
  @@index([type])
  @@index([deletedAt])
  @@map("cost_entries")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Budget {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  name      String
  amount    Decimal   @db.Decimal(18, 2)
  currency  String    @default("CNY")
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([deletedAt])
  @@map("budgets")
}
